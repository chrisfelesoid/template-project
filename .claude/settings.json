{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(cat:*)",
      "Bash(tree:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(echo:*)",
      "Bash(git add *)",
      "Bash(git commit:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(mise run:*)",
      "Bash(terraform fmt:*)"
    ],
    "deny": [
      "Read(.env)",
      "Write(.env)",
      "Read(.env.local)",
      "Write(.env.local)",
      "Read(.env.development)",
      "Write(.env.development)",
      "Read(.env.production)",
      "Write(.env.production)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gh/**)",
      "Bash(sudo:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Bash(git checkout:*)",
      "Bash(gh:*)",
      "Bash(npm publish:*)",
      "Bash(yarn publish:*)",
      "Bash(pnpm publish:*)",
      "Bash(aws:*)",
      "Bash(*deploy*)",
      "Bash(terraform apply:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(rm -r -f:*)",
      "Bash(chmod -R:*)",
      "Bash(chown -R:*)"
    ],
    "ask": ["Bash(rm:*)"]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true
  }
}
